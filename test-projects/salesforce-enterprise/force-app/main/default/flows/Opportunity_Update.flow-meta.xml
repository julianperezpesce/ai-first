<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <interviewLabel>Opportunity Update Flow-1</interviewLabel>
    <label>Opportunity Update</label>
    <processType>Flow</processType>
    <triggers>
        <name>OnOpportunityChange</name>
        <label>When an Opportunity is updated</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <触发条件>When a record is updated</触发条件>
        <object>Opportunity</object>
        <triggerType>Upon Create or Update</triggerType>
        <filters>
            <field>StageName</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
    </triggers>
    <decisions>
        <name>CheckStageChange</name>
        <label>Check Stage Change</label>
        <locationX>128</locationX>
        <locationY>224</locationY>
        <defaultConnectorLabel>No Stage Change</defaultConnectorLabel>
        <rules>
            <name>StageChangedToNegotiation</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Opportunity.StageName</leftValueReference>
                <operator>Equal</operator>
                <rightValue>
                    <stringValue>Negotiation/Review</stringValue>
                </rightValue>
            </conditions>
            <label>Stage Changed to Negotiation</label>
        </rules>
        <rules>
            <name>StageChangedToClosedWon</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Opportunity.StageName</leftValueReference>
                <operator>Equal</operator>
                <rightValue>
                    <stringValue>Closed Won</stringValue>
                </rightValue>
            </conditions>
            <label>Stage Changed to Closed Won</label>
        </rules>
    </decisions>
    <actions>
        <name>UpdateProbabilityHigh</name>
        <label>Set Probability to High</label>
        <locationX>256</locationX>
        <locationY>400</locationY>
        <actionName>FlowActionUpdateRecord</actionName>
        <actionType>UpdateRecord</actionType>
        <inputParameters>
            <name>OpportunityId</name>
            <value>
                <elementReference>$Opportunity.Id</elementReference>
            </value>
        </inputParameters>
        <object>Opportunity</object>
        <inputParameters>
            <name>Probability</name>
            <value>
                <numberValue>90</numberValue>
            </value>
        </inputParameters>
    </actions>
    <actions>
        <name>SendWinNotification</name>
        <label>Send Win Notification</label>
        <locationX>384</locationX>
        <locationY>400</locationY>
        <actionName>FlowActionSendEmail</actionName>
        <actionType>EmailAlert</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
    </actions>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>CheckStageChange</targetReference>
        </connector>
    </start>
    <status>Active</status>
</Flow>

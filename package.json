{
  "name": "ai-first",
  "version": "1.1.0",
  "name": "ai-first",
  "version": "1.0.0",
  "description": "CLI tool that prepares any repository to be used effectively by AI coding agents",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "ai-first": "dist/commands/ai-first.js"
  },
  "scripts": {
    "build": "tsc",
    "run": "node dist/commands/ai-first.js",
    "dev": "node --loader ts-node/esm src/commands/ai-first.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "ai",
    "context",
    "opencode",
    "cursor",
    "claude",
    "development",
    "tool"
  ],
  "author": "Julian Perez Pesce <julian@example.com> (https://github.com/julianperezpesce)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/julianperezpesce/ai-first.git"
  },
  "homepage": "https://julianperezpesce.github.io/ai-first",
  "bugs": {
    "url": "https://github.com/julianperezpesce/ai-first/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.30"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "sql.js": "^1.10.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.0"
  }
}

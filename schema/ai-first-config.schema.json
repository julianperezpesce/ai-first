{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI-First Configuration",
  "type": "object",
  "properties": {
    "output": {
      "type": "object",
      "properties": {
        "directory": {
          "type": "string",
          "default": "ai-context",
          "description": "Output directory for generated context files"
        }
      }
    },
    "preset": {
      "type": "string",
      "enum": ["full", "quick", "api", "docs"],
      "default": "full",
      "description": "Analysis preset determining depth and scope"
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional patterns to exclude from scanning"
    },
    "include": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File extensions to include (overrides defaults)"
    },
    "features": {
      "type": "object",
      "properties": {
        "security": { "type": "boolean", "default": true },
        "performance": { "type": "boolean", "default": true },
        "models": { "type": "boolean", "default": true },
        "crossCutting": { "type": "boolean", "default": true },
        "deadCode": { "type": "boolean", "default": false }
      }
    }
  }
}

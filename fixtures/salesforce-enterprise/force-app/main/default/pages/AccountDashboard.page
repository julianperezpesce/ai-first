<apex:page controller="AccountDashboardController" sidebar="false" showHeader="true" lightningStylesheets="true">
    <apex:form>
        <apex:pageBlock title="Account Dashboard">
            <apex:pageBlockButtons>
                <apex:commandButton value="Refresh" action="{!refreshData}" rerender="dashboardPanel"/>
                <apex:commandButton value="Export to CSV" action="{!exportToCSV}"/>
            </apex:pageBlockButtons>
            
            <apex:outputPanel id="dashboardPanel">
                <!-- Summary Section -->
                <apex:pageBlockSection title="Account Summary" columns="2">
                    <apex:outputField value="{!totalAccounts}"/>
                    <apex:outputField value="{!totalRevenue}"/>
                    <apex:outputField value="{!averageRevenue}"/>
                    <apex:outputField value="{!topIndustry}"/>
                </apex:pageBlockSection>
                
                <!-- Filters -->
                <apex:pageBlockSection title="Filters" columns="1">
                    <apex:selectList value="{!selectedIndustry}" size="1" label="Industry Filter">
                        <apex:selectOption itemValue="" itemLabel="All Industries"/>
                        <apex:selectOptions value="{!industryOptions}"/>
                        <apex:actionSupport event="onchange" rerender="accountTable"/>
                    </apex:selectList>
                    
                    <apex:inputText value="{!searchTerm}" label="Search"/>
                    <apex:commandButton value="Search" action="{!searchAccounts}" rerender="accountTable"/>
                </apex:pageBlockSection>
                
                <!-- Account Table -->
                <apex:pageBlockSection title="Accounts" columns="1">
                    <apex:pageBlockTable value="{!accounts}" var="account" rows="50">
                        <apex:column>
                            <apex:outputLink value="/{!account.Id}">{!account.Name}</apex:outputLink>
                        </apex:column>
                        <apex:column value="{!account.Industry}"/>
                        <apex:column value="{!account.AnnualRevenue}"/>
                        <apex:column value="{!account.BillingCity}"/>
                        <apex:column value="{!account.Type}"/>
                    </apex:pageBlockTable>
                </apex:pageBlockSection>
            </apex:outputPanel>
        </apex:pageBlock>
    </apex:form>
</apex:page>
